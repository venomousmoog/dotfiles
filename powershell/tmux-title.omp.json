{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "style": "mixed"
          },
          "template": "{{ .Path }}",
          "type": "path",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3,
  "final_space": false
}
