[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[user]
	name = venomousmoog
	email = venomousmoog@users.noreply.github.com

[http]
	postBuffer = 157286400

[mergetool]
    prompt = false
    keepBackup = false
    keepTemporaries = false

[push]
	autoSetupRemote = true

[submodule]
	recurse = true

[pull]
	rebase = true

[alias]
	co = checkout
	br = branch
	st = status

[include]
    path = ~/.gitconfig.os
[http "https://git.internal.tfbnw.net"]
	sslCert = /var/facebook/credentials/ddriver/x509/ddriver.pem
	sslKey = /var/facebook/credentials/ddriver/x509/ddriver.pem
[http "https://mononoke-git-lfs.internal.tfbnw.net"]
	sslCert = /var/facebook/credentials/ddriver/x509/ddriver.pem
	sslKey = /var/facebook/credentials/ddriver/x509/ddriver.pem
[http "https://manifold.c2p.facebook.net"]
	sslCert = /var/facebook/credentials/ddriver/x509/ddriver.pem
[http "https://github.com"]
	proxy = https://fwdproxy:8082
