[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[user]
	name = venomousmoog
	email = venomousmoog@users.noreply.github.com

[http]
	postBuffer = 157286400

[mergetool]
    prompt = false
    keepBackup = false
    keepTemporaries = false

[push]
	autoSetupRemote = true

[submodule]
	recurse = true

[pull]
	rebase = true

[alias]
	co = checkout
	br = branch
	st = status

[include]
    path = ~/.gitconfig.os
